<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.kyrcah.ProfileController"
      spacing="15" alignment="CENTER" style="-fx-padding: 30; -fx-background-color: #1E272E;">

    <children>
        <Label text="Мой профиль" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #FAB1A0;"/>

        <!-- Аватарка -->
        <HBox alignment="CENTER">
            <children>
                <ImageView fx:id="avatarImageView" fitWidth="180" fitHeight="180" preserveRatio="true"
                           style="-fx-effect: dropshadow(gaussian, #FAB1A0, 20, 0.4, 0, 0);"/>
            </children>
        </HBox>

        <TextField fx:id="avatarUrlField" promptText="Ссылка на фото профиля[](https://...)"/>
        <TextField fx:id="fullNameField" promptText="Полное имя"/>
        <DatePicker fx:id="birthDatePicker"/>
        <TextField fx:id="genreField" promptText="Любимый жанр"/>
        <TextArea fx:id="statusArea" promptText="Обо мне (статус)" prefHeight="100"/>

        <Label fx:id="reviewsCountLabel" text="Отзывов оставлено: 0" style="-fx-font-size: 14; -fx-text-fill: #FAB1A0;"/>

        <Button text="Сохранить изменения" onAction="#handleSaveProfile"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 15;"/>
        <Button text="Закрыть" onAction="#handleBack"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </children>
</VBox>