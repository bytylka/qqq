<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="650.0" prefWidth="950.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.kyrcah.HelloController">
    <children>
        <!-- ШАПКА -->
        <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #2D3436; -fx-padding: 10 20;">
            <children>
                <Label fx:id="userLabel" text="Гость" style="-fx-text-fill: #FAB1A0; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Button fx:id="btnLogin" text="Войти" onAction="#openLogin" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="btnRegister" text="Регистрация" onAction="#openRegister" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button fx:id="btnProfile" text="Профиль" onAction="#openProfile" visible="false" style="-fx-background-color: #FAB1A0; -fx-text-fill: #2D3436; -fx-font-weight: bold;"/>
                <Button fx:id="btnLogout" text="Выход" onAction="#handleLogout" visible="false" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
        </HBox>

        <!-- Основное содержимое -->
        <HBox prefHeight="600.0" prefWidth="950.0" spacing="10" VBox.vgrow="ALWAYS">
            <children>
                <VBox prefWidth="300.0" spacing="10.0" style="-fx-background-color: #1E272E; -fx-border-color: #535C68;">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                    </padding>
                    <children>
                        <TextField fx:id="searchField" promptText="Поиск фильмов..."/>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #DFE6E9;" text="Список фильмов"/>
                        <ListView fx:id="movieListView" VBox.vgrow="ALWAYS"/>
                    </children>
                </VBox>

                <VBox fx:id="detailsPane" spacing="20.0" visible="false" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </padding>
                    <children>
                        <Label fx:id="titleLabel" style="-fx-font-size: 32; -fx-font-weight: bold;" text="Название фильма"/>

                        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                            <tabs>
                                <!-- Информация с постером -->
                                <Tab text="Информация">
                                    <content>
                                        <VBox spacing="15.0">
                                            <padding>
                                                <Insets top="20.0"/>
                                            </padding>
                                            <children>
                                                <HBox alignment="CENTER">
                                                    <children>
                                                        <ImageView fx:id="posterImageView" fitWidth="280" fitHeight="400" preserveRatio="true"
                                                                   style="-fx-effect: dropshadow(gaussian, #FAB1A0, 20, 0.4, 0, 0);"/>
                                                    </children>
                                                </HBox>
                                                <Label fx:id="descriptionLabel" wrapText="true" style="-fx-font-size: 14;"/>
                                                <Label fx:id="ratingLabel" style="-fx-font-weight: bold; -fx-font-size: 16;" text="Рейтинг: 0.0"/>
                                                <Hyperlink fx:id="watchLink" onAction="#handleOpenLink" text="Смотреть онлайн"/>
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                                <Tab text="Отзывы">
                                    <content>
                                        <VBox spacing="10.0">
                                            <padding><Insets top="10.0"/></padding>
                                            <children>
                                                <TextArea fx:id="reviewsArea" editable="false" prefHeight="400.0" wrapText="true"/>
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                                <Tab text="Оценить">
                                    <content>
                                        <VBox spacing="15.0">
                                            <padding><Insets top="15.0"/></padding>
                                            <children>
                                                <Label text="Ваша оценка (1-10):"/>
                                                <Slider fx:id="ratingSlider" blockIncrement="1.0" majorTickUnit="1.0" max="10.0" min="1.0" minorTickCount="0" showTickLabels="true" showTickMarks="true" snapToTicks="true" value="5.0"/>
                                                <TextArea fx:id="myReviewArea" prefHeight="150.0" promptText="Напишите ваш отзыв здесь..." wrapText="true"/>
                                                <Button onAction="#handleSubmitReview" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="Отправить отзыв"/>
                                            </children>
                                        </VBox>
                                    </content>
                                </Tab>
                            </tabs>
                        </TabPane>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>