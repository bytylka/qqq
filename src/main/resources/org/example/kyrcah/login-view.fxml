<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 40;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.kyrcah.LoginController">
    <Label text="Вход в систему" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
    <TextField fx:id="loginField" promptText="Логин"/>
    <PasswordField fx:id="passwordField" promptText="Пароль"/>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Войти" onAction="#handleLogin" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
        <Button text="Регистрация" onAction="#openRegistration" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
    </HBox>
    <Label fx:id="errorLabel" textFill="RED"/>
</VBox>